# Environment Variables for Travel App

# Database (Neon PostgreSQL - get yours free at https://neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/travelapp?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/travelapp?sslmode=require"

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-min-32-chars"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"  # Change to your Netlify URL in production

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: Email Service (for email verification, password reset)
# EMAIL_FROM="noreply@yourtravelapp.com"
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"

# Optional: File Upload (for profile pictures)
# UPLOAD_MAX_SIZE="5242880" # 5MB in bytes
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"

# AI Services
# Anthropic Claude API (for itinerary generation)
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# Groq API (alternative AI provider)
GROQ_API_KEY="your-groq-api-key-here"

# Google Gemini API (for destinations and content)
GEMINI_API_KEY="your-gemini-api-key-here"
NEXT_PUBLIC_GEMINI_API_KEY="your-gemini-api-key-here"
